{
  "manifest_version": 3,
  "name": "RallySimFans Browser Plugin",
  "version": "1.5.1",
  "description": "Enhances RallySimFans website with more information",
  "content_scripts": [
    {
      "matches": [
        "*://*.rallysimfans.hu/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "rallysimfans-plugin@example.com"
    }
  }
}
