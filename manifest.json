{
  "manifest_version": 3,
  "name": "RallySimFans Browser Plugin",
  "version": "1.1.0",
  "description": "Enhances RallySimFans website with more information",
  "content_scripts": [
    {
      "matches": ["*://rallysimfans.hu/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
